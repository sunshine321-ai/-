# 环境变量（包含敏感信息）
.env

# Node
node_modules/
frontend/node_modules/
dist/
*.log
/package-lock.json
.vscode/
storage/screenshots/*
storage/exports/*
java-backend/microcourse-backend/storage/
screenshots/current-*.png
!storage/screenshots/.gitkeep
!storage/exports/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class

# Streamlit
.streamlit/

# Claude Code 本地配置 / 锁 / worktree
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/

# Word 临时锁文件
~$*
